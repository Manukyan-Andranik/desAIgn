# ==============================================================================
# Antigravity Vision OS — System Hyperparameters & Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# STAGE 1: GROUNDING DINO OBJECT DETECTOR HYPERPARAMETERS
# ------------------------------------------------------------------------------
# Minimum confidence probability threshold for detected bounding boxes (Range: 0.0 to 1.0).
# Objects with detection confidence below this threshold are filtered out.
# Set to 0.50 for high precision (50%+ probability guarantee).
GDINO_BOX_THRESHOLD=0.50

# Minimum text-matching cross-attention threshold for class phrase alignment (Range: 0.0 to 1.0).
# Determines how strictly the vision backbone aligns object proposals with prompt tokens.
GDINO_TEXT_THRESHOLD=0.50

# Class-Aware Non-Maximum Suppression (NMS) IoU overlap threshold (Range: 0.0 to 1.0).
# Merges duplicate bounding boxes of the SAME object class if their overlap ratio exceeds this value.
GDINO_NMS_THRESHOLD=0.55

# HuggingFace checkpoint model identifier for Grounding DINO vision backbone.
# Options: 'IDEA-Research/grounding-dino-base' (Swin-B high precision), 'IDEA-Research/grounding-dino-tiny'
GDINO_MODEL_ID=IDEA-Research/grounding-dino-base


# ------------------------------------------------------------------------------
# STAGE 2: SAM SUB-PIXEL SEGMENTATION HYPERPARAMETERS
# ------------------------------------------------------------------------------
# Segment Anything Model (SAM) architecture variant for sub-pixel polygon extraction.
# Options: 'vit_b' (fast & lightweight), 'vit_l' (large), 'vit_h' (huge high resolution)
SAM_MODEL_TYPE=vit_b


# ------------------------------------------------------------------------------
# STAGE 3: DEPTH ANYTHING V2 MONOCULAR ESTIMATOR HYPERPARAMETERS
# ------------------------------------------------------------------------------
# Monocular metric depth estimation HuggingFace checkpoint model string.
# Computes dense metric depth coordinates (in meters) for every detected object.
DEPTH_MODEL_ID=depth-anything/Depth-Anything-V2-Small-hf


# ------------------------------------------------------------------------------
# STAGE 4: OPENCLIP ZERO-SHOT MATERIAL CLASSIFIER HYPERPARAMETERS
# ------------------------------------------------------------------------------
# OpenCLIP vision-language model identifier for surface material & style classification.
# Predicts organic surface finishes (e.g. Bouclé, Oak Hardwood, Carrara Marble, Aniline Leather).
CLIP_MODEL_ID=openai/clip-vit-base-patch32


# ------------------------------------------------------------------------------
# CLOUD GENERATIVE AI API KEYS
# ------------------------------------------------------------------------------
REPLICATE_API_TOKEN=r8_your_actual_replicate_token_here
GEMINI_API_KEY=your_actual_gemini_api_key_here
STABILITY_API_KEY=sk_your_stability_key_here
